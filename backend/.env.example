APP_NAME=GETLANDED Voice Backend
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

SAMPLE_RATE=16000
SILENCE_FRAMES_THRESHOLD=15
VAD_THRESHOLD=0.35
MAX_BUFFER_SECONDS=30
PRELOAD_MODELS=false

WHISPER_MODEL=distil-large-v3
# Leading/trailing whitespace is trimmed at startup.
GEMINI_MODEL=gemini-2.5-flash-lite-preview-06-17
TTS_MODEL=kokoro-82m

GEMINI_API_KEY=
